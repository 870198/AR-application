<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ConelARClean.VideoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="#101010">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">

        <HorizontalStackLayout Spacing="10">
            <Button Text="Close" Clicked="OnCloseClicked" />
            <Button Text="Discord" Clicked="OnDiscordClicked" />
        </HorizontalStackLayout>

        <toolkit:MediaElement
            x:Name="PromoPlayer"
            Grid.Row="1"
            Source="conel_esports_promo.mp4"
            Aspect="AspectFit">
        </toolkit:MediaElement>

        <HorizontalStackLayout
            Grid.Row="2"
            HorizontalOptions="Center"
            Spacing="20"
            Margin="0,20,0,0">
            <Button Text="Previous" Clicked="OnPreviousClicked" />
            <Button Text="Next" Clicked="OnNextClicked" />
        </HorizontalStackLayout>

    </Grid>
</ContentPage>