<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ConelARClean.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#101010">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">
            <Label
                Text="CONEL Esports AR"
                FontSize="34"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center" />

            <Label
                Text="Use the controls below to test the AR experience, promo video, and detection log."
                FontSize="18"
                TextColor="#D1D5DB"
                HorizontalTextAlignment="Center" />

            <Button
                Text="Start AR Scan"
                Clicked="OnStartARClicked"
                BackgroundColor="#DC2626"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="54" />

            <Button
                Text="Open Promo Video"
                Clicked="OnOpenVideoClicked"
                BackgroundColor="#2563EB"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="54" />

            <Button
                Text="View Detection Log"
                Clicked="OnViewLogClicked"
                BackgroundColor="#059669"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="54" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>